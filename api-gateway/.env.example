# Sao chép thành .env và chỉnh theo môi trường.
#
# --- Chạy API Gateway trên máy (npm run dev) trong khi microservice chạy qua Docker
#     (cổng đã publish ra host, ví dụ docker-compose.core.yml) ---
# Dùng 127.0.0.1 + cổng tương ứng. KHÔNG dùng tên kiểu voice-service khi gateway chạy ngoài
# mạng Docker — sẽ lỗi ENOTFOUND và thông báo "Cannot resolve backend host for voice".
#
# VOICE_SERVICE_URL=http://127.0.0.1:3005
# USER_SERVICE_URL=http://127.0.0.1:3004
# AUTH_SERVICE_URL=http://127.0.0.1:3001
# ... (các service khác tương tự theo docker-compose.core.yml)
#
# --- Chạy toàn bộ stack trong Docker Compose ---
# Dùng tên service làm hostname (ví dụ voice-service:3005) như trong file .env mặc định của repo.

PORT=3000
NODE_ENV=development

# Ví dụ trong Docker network (đổi nếu bạn chỉ chạy gateway trên host — xem phần đầu file)
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3004
FRIEND_SERVICE_URL=http://friend-service:3014
ORGANIZATION_SERVICE_URL=http://organization-service:3013
ROLE_PERMISSION_SERVICE_URL=http://role-permission-service:3015
CHAT_SERVICE_URL=http://chat-service:3006
VOICE_SERVICE_URL=http://voice-service:3005
TASK_SERVICE_URL=http://task-service:3009
DOCUMENT_SERVICE_URL=http://document-service:3010
NOTIFICATION_SERVICE_URL=http://notification-service:3003
# Docker: hostname; gateway chạy trên host: http://127.0.0.1:3017
SOCKET_SERVICE_URL=http://socket-service:3017
VOICE_SIGNAL_PATH=/voice-socket
