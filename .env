# =============================================================================
# VoiceHub — .env gốc (Compose đọc file này cho ${VAR} và env_file)
# Chạy: docker compose từ thư mục repo.
# Mỗi service vẫn có services/<tên>/.env cho MONGODB_URI, PORT, JWT riêng.
# =============================================================================

# --- Token nội bộ (đồng bộ: gateway, user, socket, friend, notification, …) ---
USER_SERVICE_INTERNAL_TOKEN=dev-user-internal-presence-token-change-me
GATEWAY_INTERNAL_TOKEN=dev-gateway-internal-token-change-me
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me
NOTIFICATION_INTERNAL_TOKEN=dev-gateway-internal-token-change-me
REALTIME_INTERNAL_TOKEN=dev-shared-realtime-token-change-me

# --- RabbitMQ (docker-compose.infra) ---
RABBITMQ_USER=voicehub
RABBITMQ_PASS=voicehub-dev-change-me

# --- Chat / socket / worker ---
FRIEND_DM_USE_QUEUE=true

# --- DLQ / retry (task-service, ai-task-worker) ---
RABBITMQ_TASK_FROM_FILE_DLQ_QUEUE=voicehub.task.from_file.dlq
TASK_FROM_FILE_MAX_RETRIES=8
RABBITMQ_TASK_AI_DLQ_QUEUE=task-ai.dlq
AI_TASK_JOB_MAX_RETRIES=8

# --- Client Vite (tùy chọn — copy sang client/.env nếu cần) ---
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SECRET=your-nextauth-secret-key-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Kiểm tra GATEWAY_INTERNAL_TOKEN trong container (phải in OK + cùng chuỗi) ---
# Chạy từ thư mục gốc repo; sau khi sửa compose/.env: docker compose up -d --force-recreate
# docker compose exec api-gateway node -e "console.log(process.env.GATEWAY_INTERNAL_TOKEN||'MISSING')"
# docker compose exec notification-service node -e "console.log(process.env.GATEWAY_INTERNAL_TOKEN||'MISSING')"
