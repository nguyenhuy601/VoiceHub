# Sao chép thành .env và chỉnh theo môi trường local.

# API Gateway (REST)
# VITE_API_URL=http://localhost:3000

# --- Socket.IO (dev) ---
# Mặc định: cùng origin Vite → GET /socket.io được proxy tới socket-service :3017 (xem vite.config.js).
# Cần socket-service lắng nghe 3017.

# Nối thẳng socket-service (không qua proxy Vite):
# VITE_SOCKET_DIRECT_URL=http://127.0.0.1:3017

# Trong dev, muốn dùng gateway :3000 cho Socket (thay vì proxy Vite):
# VITE_SOCKET_USE_GATEWAY=true
# VITE_SOCKET_URL=http://localhost:3000

# Đổi target proxy /socket.io của Vite (mặc định http://127.0.0.1:3017), vd. test qua gateway:
# VITE_SOCKET_PROXY_TARGET=http://localhost:3000
