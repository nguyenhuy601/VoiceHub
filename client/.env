# API Gateway - khop voi service api-gateway trong docker-compose
VITE_API_URL=http://localhost:3000/api

# Tam tat auto logout khi 401 (debug). Nho dat false hoac xoa dong truoc production.
VITE_DISABLE_AUTO_LOGOUT=true

# Socket realtime:
# Ep di qua API Gateway trong dev.
VITE_SOCKET_USE_GATEWAY=true
# De trong: client tu lay host tu URL dang mo (vd. 172.16.1.29) + port gateway ben duoi.
VITE_SOCKET_URL=
VITE_GATEWAY_PORT=3000
# Neu can fallback proxy /socket.io, chi can sua target ben duoi.
VITE_SOCKET_PROXY_TARGET=http://127.0.0.1:3000
VITE_VOICE_SIGNAL_PATH=/voice-socket

# FE host/port co the doi linh hoat qua env
VITE_HOST=0.0.0.0
VITE_PORT=5173

VITE_APP_NAME=Voice Chat App
VITE_APP_VERSION=1.0.0
