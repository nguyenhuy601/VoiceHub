# API Gateway – khớp với service api-gateway trong docker-compose
VITE_API_URL=http://localhost:3000/api

# Tạm tắt auto logout khi 401 (debug). Nhớ đặt false hoặc xóa dòng trước production.
VITE_DISABLE_AUTO_LOGOUT=true

# Socket realtime: base gateway — client tự nối /chat (namespace socket-service)
VITE_SOCKET_URL=http://localhost:3000
# Dev: Vite proxy /socket.io → api-gateway (gateway proxy tiếp tới socket-service trong Docker)
VITE_SOCKET_PROXY_TARGET=http://localhost:3000
VITE_VOICE_SIGNAL_PATH=/voice-socket

VITE_APP_NAME=Voice Chat App
VITE_APP_VERSION=1.0.0