#TTL file (tùy chọn)
FILE_RETENTION_DM_DAYS=180
FILE_RETENTION_ORG_DAYS=365
FILE_RETENTION_MEETING_HOURS=6
FILE_UPLOAD_MAX_MB=50

# GC Storage (cron trong chat-service)
STORAGE_GC_ENABLED=true
STORAGE_GC_INTERVAL_MS=3600000

# MIME cho phép khi xin signed URL (prefix, phân tách dấu phẩy). Thêm application/vnd.openxmlformats cho .docx/.xlsx/.pptx; application/msword cho .doc; application/octet-stream khi trình duyệt không gửi type.
FILE_ALLOWED_MIME=image/,video/,audio/,text/,application/pdf,application/rtf,application/vnd.openxmlformats,application/msword,application/vnd.ms-,application/x-msword,application/zip,application/x-zip-compressed,application/json,application/xml,application/vnd.oasis.opendocument,application/octet-stream

