# Chat Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3006

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/chat_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (để verify token từ auth-service)
JWT_SECRET=your-secret-key-change-in-production

# Mã hóa at-rest cho nội dung tin nhắn (AES-256-GCM) — 32+ ký tự hoặc 64 ký tự hex
ENCRYPTION_MASTER_KEY=b1837e3abe2919701792faa053dc60865bfc48ed78a70f00b9ca314a419404ac

# External Services
USER_SERVICE_URL=http://user-service:3004
ORGANIZATION_SERVICE_URL=http://organization-service:3013
SOCKET_SERVICE_URL=http://socket-service:3017
REALTIME_INTERNAL_TOKEN=dev-shared-realtime-token-change-me

# Firebase Storage (signed URL upload — service account, không commit JSON)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# TTL file (tùy chọn)
# FILE_RETENTION_DM_DAYS=180
# FILE_RETENTION_ORG_DAYS=365
# FILE_RETENTION_MEETING_HOURS=6
# FILE_UPLOAD_MAX_MB=50

# MIME cho phép khi xin signed URL (prefix, phân tách dấu phẩy). Bỏ dòng này để dùng mặc định đầy đủ trong code. Nếu set: thêm application/vnd.openxmlformats (.docx/.xlsx/.pptx), application/msword (.doc), application/octet-stream (một số trình duyệt).
# FILE_ALLOWED_MIME=image/,video/,audio/,text/,application/pdf,application/rtf,application/vnd.openxmlformats,application/msword,application/vnd.ms-,application/octet-stream

# GC Storage (cron trong chat-service)
# STORAGE_GC_ENABLED=true
# STORAGE_GC_INTERVAL_MS=3600000
