# AI Task Worker Environment Variables
NODE_ENV=development

# Mongo (dev local; có thể override)
MONGODB_URI=mongodb://admin:password@mongodb:27017/ai_task_db?authSource=admin

# RabbitMQ
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@rabbitmq:5672
RABBITMQ_TASK_AI_EXTRACT_QUEUE=task-ai.extract
RABBITMQ_TASK_AI_SYNC_QUEUE=task-ai.sync

# Ollama — bắt buộc pull model ít nhất một lần (404 = model chưa có trên máy Ollama):
#   docker exec enterprise-ollama ollama pull qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# OCR service (Phase 4)
PADDLEOCR_BASE_URL=http://paddleocr-service:8000

# Downstream services (Phase 3)
CHAT_SERVICE_URL=http://chat-service:3006
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me
USER_SERVICE_URL=http://user-service:3004
TASK_SERVICE_URL=http://task-service:3009

