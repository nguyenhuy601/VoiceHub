# AI Task Service Environment Variables
NODE_ENV=development
PORT=3020

# Mongo (dev local; có thể override bằng env của host)
MONGODB_URI=mongodb://admin:password@mongodb:27017/ai_task_db?authSource=admin

# RabbitMQ
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@rabbitmq:5672
RABBITMQ_TASK_AI_EXTRACT_QUEUE=task-ai.extract
RABBITMQ_TASK_AI_SYNC_QUEUE=task-ai.sync

# Downstream services (internal)
CHAT_SERVICE_URL=http://chat-service:3006
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me
TASK_SERVICE_URL=http://task-service:3009

# Ollama endpoint (worker sẽ gọi; service chỉ publish job)
OLLAMA_BASE_URL=http://ollama:11434

