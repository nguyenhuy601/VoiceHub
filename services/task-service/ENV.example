# Task Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3009

# Database
# — Atlas: mongodb+srv://USER:PASS@cluster.../task_db (whitelist IP; không dùng localhost trong URI)
# — Docker Compose (service mongodb): hostname phải là `mongodb`, KHÔNG dùng localhost trong container
#   Ví dụ: mongodb://admin:password@mongodb:27017/task_db?authSource=admin
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/task_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
ORGANIZATION_SERVICE_URL=http://organization-service:3013
USER_SERVICE_URL=http://user-service:3004
WEBHOOK_SERVICE_URL=http://webhook-service:3016
WEBHOOK_SECRET=your-webhook-secret-key-change-this-in-production
