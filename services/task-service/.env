# Task Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3009

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/task_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
ORGANIZATION_SERVICE_URL=http://organization-service:3013
USER_SERVICE_URL=http://user-service:3004
WEBHOOK_SERVICE_URL=http://webhook-service:3016
WEBHOOK_SECRET=your-webhook-secret-key-change-this-in-production
CHAT_SERVICE_URL=http://chat-service:3006
CHAT_INTERNAL_TOKEN=dev-shared-chat-internal-token-change-me

# RabbitMQ — worker tạo task từ file
