# User Service — PII at-rest (phone/bio/location) + blind index
# ENCRYPTION_MASTER_KEY: 32+ ký tự UTF-8 hoặc 64 ký tự hex (32 byte)
ENCRYPTION_MASTER_KEY=

# Token nội bộ — socket-service gọi PATCH /api/users/internal/status (presence online/offline)
# Phải trùng USER_SERVICE_INTERNAL_TOKEN trên socket-service
USER_SERVICE_INTERNAL_TOKEN=dev-user-internal-presence-token-change-me
