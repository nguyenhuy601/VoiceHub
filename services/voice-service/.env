# Voice Service Environment Variables
# Copy this file to .env and update the values

# Server
NODE_ENV=development
PORT=3005
JWT_SECRET=your-secret-key-change-in-production

# Database
MONGODB_URI=mongodb+srv://nguyenhuy6012004_db_user:nhathuy0305@cluster0.ccaayy0.mongodb.net/voice_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# External Services
USER_SERVICE_URL=http://user-service:3004
ORGANIZATION_SERVICE_URL=http://organization-service:3013

# Voice Signaling
VOICE_SIGNAL_PATH=/voice-socket
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Mediasoup / WebRTC
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_LOG_LEVEL=warn
MEDIASOUP_INITIAL_OUTGOING_BITRATE=1000000
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100

