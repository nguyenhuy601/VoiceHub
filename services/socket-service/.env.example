PORT=3017
NODE_ENV=development
# Production: CORS_ORIGIN = danh sách origin HTTPS (không wildcard)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# URL nội bộ tới các service khác trong docker-compose
CHAT_SERVICE_URL=http://chat-service:3006
USER_SERVICE_URL=http://user-service:3004

# Redis (presence + Socket.IO Redis adapter — scale ngang)
REDIS_HOST=redis
REDIS_PORT=6379
# SOCKET_IO_REDIS_ADAPTER=false

# RabbitMQ — publish DM bất đồng bộ (consumer ở chat-service)
RABBITMQ_URL=amqp://voicehub:voicehub-dev-change-me@rabbitmq:5672
FRIEND_DM_USE_QUEUE=true

REALTIME_INTERNAL_TOKEN=

# Trùng USER_SERVICE_INTERNAL_TOKEN trên user-service — đồng bộ online/offline khi socket connect/disconnect
USER_SERVICE_INTERNAL_TOKEN=dev-user-internal-presence-token-change-me

# Phải trùng với JWT_SECRET bên auth-service và /shared
JWT_SECRET=your-secret-key

