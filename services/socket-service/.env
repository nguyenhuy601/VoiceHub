PORT=3017
# Dev: để trống để socket-service allow-all origins (phù hợp khi Vite chạy --host 0.0.0.0 và truy cập bằng IP LAN)
CORS_ORIGIN=

# URL nội bộ tới các service khác trong docker-compose
CHAT_SERVICE_URL=http://chat-service:3006

# Phải trùng với JWT_SECRET bên auth-service và /shared
JWT_SECRET=your-secret-key-change-in-production


# Trùng USER_SERVICE_INTERNAL_TOKEN trên user-service — đồng bộ online/offline khi socket connect/disconnect
USER_SERVICE_INTERNAL_TOKEN=dev-user-internal-presence-token-change-me
# # Kafka
# KAFKA_ENABLED=true
# KAFKA_BROKERS=kafka:9092
# KAFKA_CLIENT_ID=socket-service
# KAFKA_GROUP_ID=socket-service-group
# KAFKA_TOPIC_CHAT_FRIEND_MESSAGE_SEND=chat.friend.message.send.v1
# KAFKA_TOPIC_DEAD_LETTER=dead.letter.v1
