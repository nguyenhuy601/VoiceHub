rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidString(text, minLen, maxLen) {
      return text is string 
        && text.size() >= minLen 
        && text.size() <= maxLen;
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      allow create: if isOwner(userId) 
        && request.resource.data.uid == userId;
      
      allow update: if isOwner(userId);
      
      // Only owner can delete their profile
      allow delete: if isOwner(userId);
    }
    
    // Discord servers collection
    match /discord/{serverId} {
      // Anyone authenticated can read servers
      allow read: if isAuthenticated();
      
      // Authenticated users can create servers
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.serverName, 3, 50)
        && isValidString(request.resource.data.description, 10, 500)
        && isValidString(request.resource.data.adminName, 2, 30);
      
      // Only server owner can update
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      // Only server owner can delete
      allow delete: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
      
      // Chat messages subcollection
      match /chat/{messageId} {
        // Anyone in the server can read messages
        allow read: if isAuthenticated();
        
        // Authenticated users can create messages
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && (
            isValidString(request.resource.data.message, 1, 2000)
            || request.resource.data.chatImage is string
          );
        
        // Only message owner can update their message
        allow update: if isAuthenticated() 
          && resource.data.userId == request.auth.uid;
        
        // Only message owner can delete their message
        allow delete: if isAuthenticated() 
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
