STACK_NAME=voicehub

# Registry and tag
REGISTRY=ghcr.io
OWNER=your-org
TAG=latest

API_GATEWAY_IMAGE=${REGISTRY}/${OWNER}/voicehub/api-gateway:${TAG}
AUTH_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/auth-service:${TAG}
USER_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/user-service:${TAG}
ORGANIZATION_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/organization-service:${TAG}
FRIEND_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/friend-service:${TAG}
ROLE_PERMISSION_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/role-permission-service:${TAG}
CHAT_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/chat-service:${TAG}
TASK_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/task-service:${TAG}
AI_TASK_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/ai-task-service:${TAG}
AI_TASK_WORKER_IMAGE=${REGISTRY}/${OWNER}/voicehub/ai-task-worker:${TAG}
DOCUMENT_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/document-service:${TAG}
VOICE_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/voice-service:${TAG}
NOTIFICATION_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/notification-service:${TAG}
WEBHOOK_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/webhook-service:${TAG}
SOCKET_SERVICE_IMAGE=${REGISTRY}/${OWNER}/voicehub/socket-service:${TAG}

# Recommended replicas (Plan A + B baseline)
TASK_WORKER_REPLICAS=1
AI_TASK_WORKER_REPLICAS=0
AI_TASK_EXTRACT_WORKER_REPLICAS=1
AI_TASK_SYNC_WORKER_REPLICAS=1
NOTIFICATION_DISPATCH_WORKER_REPLICAS=1
WEBHOOK_DELIVERY_WORKER_REPLICAS=1
SOCKET_SERVICE_REPLICAS=2
